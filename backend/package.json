{
  "name": "ats-backend",
  "version": "1.0.0",
  "description": "ATS (Applicant Tracking System) Backend - Migrated from n8n workflows",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:staging": "cross-env NODE_ENV=staging node src/server.js",
    "start:prod": "cross-env NODE_ENV=production node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:staging": "cross-env NODE_ENV=staging nodemon src/server.js",
    "prisma:pull": "npx prisma db pull",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "seed:recipients:staging": "cross-env NODE_ENV=staging node prisma/seed-email-recipients.js",
    "seed:recipients:prod": "cross-env NODE_ENV=production node prisma/seed-email-recipients.js",
    "zeko:token:staging": "cross-env NODE_ENV=staging node scratch/run_zeko_sync.js token",
    "zeko:cookie:staging": "cross-env NODE_ENV=staging node scratch/run_zeko_sync.js cookie",
    "zeko:jobs:staging": "cross-env NODE_ENV=staging node scratch/run_zeko_sync.js jobs",
    "zeko:results:staging": "cross-env NODE_ENV=staging node scratch/run_zeko_sync.js results",
    "zeko:token:prod": "cross-env NODE_ENV=production node scratch/run_zeko_sync.js token",
    "zeko:cookie:prod": "cross-env NODE_ENV=production node scratch/run_zeko_sync.js cookie",
    "zeko:jobs:prod": "cross-env NODE_ENV=production node scratch/run_zeko_sync.js jobs",
    "zeko:results:prod": "cross-env NODE_ENV=production node scratch/run_zeko_sync.js results",
    "queue:worker": "node src/workers/resumeWorker.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.9.0",
    "adm-zip": "^0.5.17",
    "bullmq": "^5.34.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^30.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.9.0",
    "supertest": "^7.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ats",
    "applicant-tracking",
    "recruitment",
    "express",
    "prisma",
    "bullmq"
  ],
  "license": "UNLICENSED",
  "private": true
}
