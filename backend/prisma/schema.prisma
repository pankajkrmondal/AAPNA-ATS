generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model rpa_users {
  id                   Int                      @id @default(autoincrement())
  username             String                   @unique @db.VarChar(100)
  password_hash        String
  role                 String?                  @default("recruiter") @db.VarChar(50)
  is_active            Boolean?                 @default(true)
  created_at           DateTime?                @default(now()) @db.Timestamp(6)
  first_name           String?                  @db.VarChar(100)
  last_name            String?                  @db.VarChar(100)
  email                String?                  @unique(map: "idx_rpa_users_email") @db.VarChar(255)
  is_approved          Boolean?                 @default(false)
  department           String?                  @default("HR") @db.VarChar(100)
  rpa_email_messages   rpa_email_messages[]
  rpa_email_templates  rpa_email_templates[]
  module_permissions   rpa_module_permissions[]
  rpa_outlook_accounts rpa_outlook_accounts[]
  sessions             rpa_sessions[]

  @@map("rpa_users")
}

model rpa_sessions {
  id         Int        @id @default(autoincrement())
  token      String     @unique
  user_id    Int?
  role       String?    @db.VarChar(50)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  expires_at DateTime   @db.Timestamp(6)
  user       rpa_users? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("rpa_sessions")
}

model rpa_module_permissions {
  user_id    Int
  module_key String    @db.VarChar(50)
  is_enabled Boolean   @default(false)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  user       rpa_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, module_key])
  @@map("rpa_module_permissions")
}

model rpa_cv {
  id                           BigInt                       @id @default(autoincrement())
  Name                         String?
  NoticePeriod                 String?
  ContactNumber                String?
  EmailID                      String?
  HighestQualification         String?
  TotalExperienceYears         String?
  LastCompanyExperienceYears   String?
  CurrentLocation              String?
  CTC_LPA                      String?
  ExpectedCTC_LPA              String?
  JobSource                    String?
  RecruiterInfoAAPNA           String?
  PositionApplied              String?
  Top5KeySkills                String?
  CurrentCompany               String?
  Gender                       String?
  EnglishCommunicationRating   String?
  PreferredShift               String?
  ReasonForJobChange           String?
  WillingToTakeOnlineTest      String?
  HasLaptopForInitialDays      String?
  EducationalScoresPercentage  String?
  LinkedInProfile              String?
  MetaData                     String?                      @default("")
  statusActive                 String?
  missingData                  String?
  cvMissingToken               String?
  cvMissingTokenStatus         String?
  createdAt                    DateTime?                    @db.Timestamp(6)
  modifiedAt                   DateTime?                    @db.Timestamp(6)
  vendorName                   String?
  lockForNinetyDays            String?
  VendorEmail                  String?
  a10th                        String?                      @db.VarChar
  a12th                        String?                      @db.VarChar
  graduation                   String?                      @db.VarChar
  postGraduation               String?                      @db.VarChar
  Heat                         String?
  HRQuickcomments              String?
  IQScore                      String?
  TechScore                    String?
  FinalStatus                  String?
  TechRoundOne                 String?
  TechRoundTwo                 String?
  ManagerialOrCEOFeedback      String?
  HRInterview                  String?
  ZekoInterviewScore           Decimal?                     @db.Decimal
  ZekoCodingScore              Decimal?                     @db.Decimal
  ZekoCommunicationScore       Decimal?                     @db.Decimal
  TechRoundThree               String?
  graduationdegree             String?
  graduationspecialization     String?
  postgraduationdegree         String?
  postgraduationspecialization String?
  employment_history           Json?
  cvVectorLock                 String?
  cvFileUrl                    String?
  resume_full_text             String?
  resume_text_quality          String?                      @default("unknown") @db.VarChar(20)
  resume_technical_terms       Json?                        @default("[]")
  resume_term_updated_at       DateTime?                    @db.Timestamptz(6)
  resume_tsvector              Unsupported("tsvector")?
  TotalExperienceYearsNumeric  Decimal?                     @db.Decimal(5, 2)
  ExpectedCTCNumeric           Decimal?                     @db.Decimal(10, 2)
  NoticePeriodDays             Int?
  ai_profile_insights          Json?
  emails                       rpa_email_messages[]
  shortlisted                  rpa_shortlisted_candidates[]

  @@index([resume_tsvector], map: "idx_rpa_cv_resume_tsvector", type: Gin)
  @@index([TotalExperienceYearsNumeric], map: "idx_rpa_cv_total_exp_num")
  @@index([ExpectedCTCNumeric], map: "idx_rpa_cv_expected_ctc_num")
  @@index([NoticePeriodDays], map: "idx_rpa_cv_notice_days")
  @@map("rpa_cv")
}

model rpa_mrf {
