model rpa_zeko_jobs {
  id                   Int       @id @default(autoincrement())
  zeko_id              String    @unique
  job_ref_id           String?
  title                String?
  hiring_name          String?
  role_name            String?
  status               String?   @default("draft")
  interview_type       String?
  is_published         Boolean?  @default(false)
  is_workflow_pub      Boolean?  @default(false)
  is_archived          Boolean?  @default(false)
  is_hr_screening      Boolean?  @default(false)
  is_coding            Boolean?  @default(false)
  slug                 String?
  email                String?
  company_name         String?   @default("Aapna Infotech")
  total_applicants     Int?      @default(0)
  resume_count         Int?      @default(0)
  screening_count      Int?      @default(0)
  functional_count     Int?      @default(0)
  created_at_zeko      DateTime? @db.Timestamptz(6)
  updated_at_zeko      DateTime? @db.Timestamptz(6)
  raw_steps            String?
  synced_at            DateTime? @default(now()) @db.Timestamptz(6)
  interview_ids        Json?     @default("[]")
  primary_interview_id String?   @default(dbgenerated("\nCASE\n    WHEN (jsonb_array_length(interview_ids) > 0) THEN ((interview_ids -> 0) ->> '_id'::text)\n    ELSE NULL::text\nEND"))

  @@index([status], map: "idx_rpa_zeko_jobs_status")
  @@index([synced_at(sort: Desc)], map: "idx_rpa_zeko_jobs_synced")
  @@index([interview_type], map: "idx_rpa_zeko_jobs_type")
}

model rpa_zeko_sync_log {
  id            Int       @id @default(autoincrement())
  execution_id  String?
  total_fetched Int?      @default(0)
  synced_at     DateTime? @default(now()) @db.Timestamptz(6)
  status        String?   @default("success")
}

model rpa_cv_vectors {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text         String?
  metadata     Json?
  embedding    Unsupported("vector")?
  unique_key   String?
  candidate_id BigInt?

  @@index([candidate_id], map: "idx_rpa_cv_vectors_candidate_id")
  @@map("rpa_cv_vectors")
}

enum approval_status {
  pending
  approved
  rejected
}
