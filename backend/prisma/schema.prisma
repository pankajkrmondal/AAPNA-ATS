  submitter_email               String?
  hiring_manager_name           String?
  hiring_manager_designation    String?
  date_of_request               DateTime?                    @db.Date
  required_in                   String?
  position_hiring_for           String?
  number_of_positions           Int?
  position_reports_to           String?
  requirement_for_team          String?
  desired_qualification         String?
  pg_information                String?
  graduate_other_information    String?
  replacement_or_new_role       String?
  replacement_comments          String?
  total_years_of_experience     Int?
  relevant_years_of_experience  Int?
  project_name                  String?
  project_duration              String?
  employment_type               String?
  existing_resource_allocation  Boolean?
  existing_resource_information String?
  roles_responsibilities        String?
  mandatory_skills              String?
  good_to_have_skills           String?
  first_technical_round         String?
  second_technical_round        String?
  ceo_management_round          String?
  hr_round                      String?
  client_round                  String?
  client_round_coordinator      String?
  job_timing                    String?
  first_round_interview_slot    String?
  second_round_interview_slot   String?
  weekly_meeting_slot           String?
  client_details                String?
  additional_information        String?
  competencies_required         String?
  question_paper                String?
  approved_by_abhijit           String?
  jd_attachment                 String?
  online_test_paper_attachment  String?
  created_at                    DateTime?                    @default(now()) @db.Timestamp(6)
  approval_status               String                       @default("pending")
  emailbody                     String?
  requirement_for_team_other    String?
  other_qualification_more_info String?
  roles_responsibilities_other  String?
  ceo_panel_details             String?
  question_paper_new_owner      String?
  jd_document_link              String?
  parsed_jd_json                Json?
  mandatory_skills_other        String?
  good_to_have_skills_other     String?
  emails                        rpa_email_messages[]
  shortlisted                   rpa_shortlisted_candidates[]

  @@map("rpa_mrf")
}

model rpa_shortlisted_candidates {
  id                          Int                           @id @default(autoincrement())
  cv_id                       BigInt?
  mrf_id                      BigInt?
  candidate_name              String                        @db.VarChar(255)
  candidate_email             String                        @db.VarChar(255)
  position_applied            String?                       @db.VarChar(255)
  shortlisted_by              String?                       @db.VarChar(255)
  shortlisted_at              DateTime?                     @default(now()) @db.Timestamp(6)
  recruiter_notes             String?
  email_sent                  Boolean?                      @default(false)
  email_sent_at               DateTime?                     @db.Timestamp(6)
  email_subject               String?                       @db.VarChar(500)
  email_body_snapshot         String?
  pipeline_status             String?                       @default("shortlisted") @db.VarChar(50)
  interview_r1_at             DateTime?                     @db.Timestamp(6)
  interview_r2_at             DateTime?                     @db.Timestamp(6)
  offer_sent_at               DateTime?                     @db.Timestamp(6)
  offer_accepted_at           DateTime?                     @db.Timestamp(6)
  joined_at                   DateTime?                     @db.Timestamp(6)
  stage_notes                 String?
  created_at                  DateTime?                     @default(now()) @db.Timestamp(6)
  modified_at                 DateTime?                     @default(now()) @db.Timestamp(6)
  candidate_email_all         String?
  emails                      rpa_email_messages[]
  cv                          rpa_cv?                       @relation(fields: [cv_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mrf                         rpa_mrf?                      @relation(fields: [mrf_id], references: [id], onUpdate: NoAction)
  rpa_zeko_candidate_pipeline rpa_zeko_candidate_pipeline[]

  @@map("rpa_shortlisted_candidates")
}

model rpa_upload_log {
  id           Int       @id @default(autoincrement())
  execution_id String
  file_name    String
  status       String
  source       String?
  processed_at DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([execution_id, file_name])
  @@unique([execution_id, file_name], map: "uq_exec_file")
  @@index([execution_id], map: "idx_upload_log_exec")
  @@map("rpa_upload_log")
}

model rpa_upload_batch_summary {
  id              Int       @id @default(autoincrement())
  execution_id    String    @unique @db.VarChar(100)
  uploaded_by     String    @db.VarChar(100)
  uploaded_at     DateTime? @default(now()) @db.Timestamptz(6)
  total_count     Int       @default(0)
  success_count   Int       @default(0)
  update_count    Int       @default(0)
  duplicate_count Int       @default(0)
  failed_count    Int       @default(0)
  details         Json?

  @@map("rpa_upload_batch_summary")
}

model rpa_email_messages {
  id                   Int                         @id @default(autoincrement())
  graph_message_id     String?                     @unique
  conversation_id      String
  internet_msg_id      String?
  in_reply_to          String?
  from_email           String
  from_name            String?
  to_emails            String[]
  cc_emails            String[]
  bcc_emails           String[]
  subject              String?
  body_preview         String?
  body_html            String?
  has_attachments      Boolean?                    @default(false)
  attachments_json     Json?
  direction            String
  folder               String?                     @default("inbox")
  candidate_id         BigInt?
  mrf_id               BigInt?
  shortlist_id         Int?
  account_id           Int?
  sent_by_user_id      Int?
  sent_at              DateTime?                   @db.Timestamp(6)
  received_at          DateTime?                   @db.Timestamp(6)
  created_at           DateTime?                   @default(now()) @db.Timestamp(6)
  template_id          Int?
  rpa_outlook_accounts rpa_outlook_accounts?       @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  candidate            rpa_cv?                     @relation(fields: [candidate_id], references: [id], onUpdate: NoAction)
  mrf                  rpa_mrf?                    @relation(fields: [mrf_id], references: [id], onUpdate: NoAction)
  rpa_users            rpa_users?                  @relation(fields: [sent_by_user_id], references: [id], onUpdate: NoAction)
  shortlist            rpa_shortlisted_candidates? @relation(fields: [shortlist_id], references: [id], onUpdate: NoAction)
  rpa_email_templates  rpa_email_templates?        @relation(fields: [template_id], references: [id], onUpdate: NoAction)
  rpa_email_tracking   rpa_email_tracking[]

  @@index([account_id], map: "idx_email_messages_account")
  @@index([candidate_id], map: "idx_email_messages_candidate")
  @@index([conversation_id], map: "idx_email_messages_conversation")
  @@index([direction], map: "idx_email_messages_direction")
  @@index([from_email], map: "idx_email_messages_from")
  @@index([mrf_id], map: "idx_email_messages_mrf")
  @@index([sent_at(sort: Desc)], map: "idx_email_messages_sent_at")
  @@index([shortlist_id], map: "idx_email_messages_shortlist")
  @@map("rpa_email_messages")
}

model rpa_email_notifications {
  id              Int       @id @default(autoincrement())
  candidate_name  String?
