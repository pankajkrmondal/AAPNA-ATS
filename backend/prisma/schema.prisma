  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  created_by   String?   @default("api_key_workflow")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model rpa_zeko_candidate_pipeline {
  id                         Int                        @id @default(autoincrement())
  candidate_id               Int
  zeko_job_id                String
  pipeline_id                String
  stage                      String                     @default("hr")
  status                     String                     @default("pending")
  link_sent_at               DateTime?                  @db.Timestamptz(6)
  completed_at               DateTime?                  @db.Timestamptz(6)
  created_at                 DateTime                   @default(now()) @db.Timestamptz(6)
  candidate_email            String?
  interview_start_at         DateTime?                  @db.Timestamptz(6)
  interview_end_at           DateTime?                  @db.Timestamptz(6)
  cancelled_at               DateTime?                  @db.Timestamptz(6)
  cancel_reason              String?
  rpa_shortlisted_candidates rpa_shortlisted_candidates @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([candidate_id, zeko_job_id, stage])
  @@index([candidate_id], map: "idx_zeko_pipeline_candidate")
  @@index([zeko_job_id], map: "idx_zeko_pipeline_job")
  @@index([status], map: "idx_zeko_pipeline_status")
}

