model rpa_email_templates {
  id                 Int                  @id @default(autoincrement())
  name               String
  category           String?              @default("general")
  subject            String
  body_html          String
  placeholders       String[]
  created_by         Int?
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  modified_at        DateTime?            @default(now()) @db.Timestamp(6)
  rpa_email_messages rpa_email_messages[]
  rpa_users          rpa_users?           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model rpa_email_tracking {
  id                 Int                @id @default(autoincrement())
  message_id         Int
  tracking_token     String?            @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  delivered          Boolean?           @default(false)
  delivered_at       DateTime?          @db.Timestamp(6)
  opened             Boolean?           @default(false)
  first_opened_at    DateTime?          @db.Timestamp(6)
  open_count         Int?               @default(0)
  last_opened_at     DateTime?          @db.Timestamp(6)
  replied            Boolean?           @default(false)
  replied_at         DateTime?          @db.Timestamp(6)
  bounced            Boolean?           @default(false)
  bounce_reason      String?
  created_at         DateTime?          @default(now()) @db.Timestamp(6)
  rpa_email_messages rpa_email_messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([message_id], map: "idx_email_tracking_message")
  @@index([tracking_token], map: "idx_email_tracking_token")
}

