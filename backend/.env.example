NODE_ENV=development
PORT=5000

# PostgreSQL (existing database)
DATABASE_URL=postgresql://user:password@localhost:5432/ats_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Microsoft Graph API
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=
MS_ONEDRIVE_PARENT_ID=

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Zeko AI
ZEKO_API_URL=
ZEKO_API_KEY=

# File Upload
UPLOAD_MAX_SIZE=50mb
UPLOAD_DIR=./uploads

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# n8n Webhook URL Prefix (Leave empty if not using n8n)
N8N_WEBHOOK_URL_PREFIX=

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Cohere Reranking
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v2/rerank
COHERE_MODEL=rerank-v3.5
