# ─────────────────────────────────────────────────────────────────────────
# PRODUCTION environment (.env.production)
# Copy to `.env.production` and fill in. Loaded when NODE_ENV=production
# (npm run start:prod). In production mail is sent to the REAL recipients;
# per-flow recipients live in the production database's rpa_settings table
# (seed: npm run seed:recipients:prod).
# ─────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# PostgreSQL — PRODUCTION database
DATABASE_URL="postgresql://appuser:PASSWORD@HOST:5432/recruitmentautomationdbProd?schema=public&connection_limit=5&pool_timeout=20&connect_timeout=10"

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — use a strong, unique secret in production
JWT_SECRET=change-me-strong-unique
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Microsoft Graph API (Outlook) — production "AAPNA Recruitment" mailbox / app + prod OneDrive
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=
MS_ONEDRIVE_PARENT_ID=
MS_DEFAULT_SENDER_EMAIL=recruitment@aapnainfotech.in

# Non-prod redirect inbox — unused in production (kept for completeness)
EMAIL_STAGING_RECIPIENTS=

# Outlook mailbox pollers (poll the MS_DEFAULT_SENDER_EMAIL mailbox).
# These replace the n8n "Outlook Trigger2" (email resume intake) and
# "WF2 Incoming Email Sync" (inbound conversation sync) workflows. Turn ON in
# production once the AAPNA Recruitment mailbox poll is validated.
EMAIL_INTAKE_ENABLED=true
EMAIL_INTAKE_CRON=*/5 * * * *
INBOUND_SYNC_ENABLED=true
INBOUND_SYNC_CRON=*/5 * * * *

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Zeko AI
ZEKO_API_URL=
ZEKO_API_KEY=
ZEKO_SCHEDULE_API_BASE=https://interview-api.zeko.ai/api/v1
ZEKO_INTERVIEW_LINK_BASE=https://interview.zeko.ai/interview
# Background Zeko sync (token refresh + job catalog + interview results).
# Use the PRODUCTION clientId here. companyId is shared across envs.
ZEKO_CLIENT_ID=
ZEKO_COMPANY_ID=6748052622c18816256a2d9e
ZEKO_DASHBOARD_API_BASE=https://interview-api.zeko.ai/dashboard/api/v2
# OTP login → dashboard cookie (job catalog auth). Login email defaults to MS_DEFAULT_SENDER_EMAIL.
ZEKO_LOGIN_API_BASE=https://api.zeko.ai/mygurukul
ZEKO_LOGIN_EMAIL=
ZEKO_SYNC_ENABLED=false
ZEKO_JOBS_CRON=0 * * * *
ZEKO_RESULTS_CRON=30 * * * *

# File Upload
UPLOAD_MAX_SIZE=50mb
UPLOAD_DIR=./uploads

# Frontend URL — production domain (used for CORS and email links)
FRONTEND_URL=https://ats.aapnainfotech.com

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-nano

# Cohere Reranking
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v2/rerank
COHERE_MODEL=rerank-v3.5
