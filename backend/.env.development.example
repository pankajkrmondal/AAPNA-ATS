# ─────────────────────────────────────────────────────────────────────────
# DEVELOPMENT environment (.env.development)
# Copy to `.env.development` and fill in. Loaded automatically when
# NODE_ENV=development (the default). In any non-production environment ALL
# outgoing mail is redirected to EMAIL_STAGING_RECIPIENTS.
# ─────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# PostgreSQL — staging database for local dev
DATABASE_URL="postgresql://appuser:PASSWORD@HOST:5432/recruitmentautomationdb?schema=public&connection_limit=3&pool_timeout=20&connect_timeout=10"

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Microsoft Graph API (Outlook) — staging "Saurabh" mailbox / app
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=
MS_ONEDRIVE_PARENT_ID=
MS_DEFAULT_SENDER_EMAIL=pkmondal@aapnainfotech.com

# Internal inbox that receives ALL mail in non-production environments
EMAIL_STAGING_RECIPIENTS=n8npankajmondal@gmail.com,hmopuri@aapnainfotech.com

# Outlook mailbox pollers (poll the MS_DEFAULT_SENDER_EMAIL mailbox). Default OFF.
# EMAIL_INTAKE: ingest resumes that arrive as email attachments (n8n "Outlook Trigger2").
# INBOUND_SYNC: record inbound replies into the conversation view (n8n "WF2").
EMAIL_INTAKE_ENABLED=false
EMAIL_INTAKE_CRON=*/5 * * * *
INBOUND_SYNC_ENABLED=false
INBOUND_SYNC_CRON=*/5 * * * *

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Zeko AI
ZEKO_API_URL=
ZEKO_API_KEY=
ZEKO_SCHEDULE_API_BASE=https://interview-api.zeko.ai/api/v1
ZEKO_INTERVIEW_LINK_BASE=https://interview.zeko.ai/interview

# File Upload
UPLOAD_MAX_SIZE=50mb
UPLOAD_DIR=./uploads

# Frontend URL — used for CORS and for links built into emails
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-nano

# Cohere Reranking
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/v2/rerank
COHERE_MODEL=rerank-v3.5
